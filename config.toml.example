# Tor Marketplace Configuration
# Copy this to config.toml and fill in your values

# ===================
# DATABASE
# ===================
[database]
type = "sqlite"
path = "data/marketplace.db"

# For production (PostgreSQL), uncomment below:
# [database]
# type = "postgres"
# url = "postgres://user:pass@localhost/marketplace"

# ===================
# SERVER
# ===================
[server]
listen_addr = "127.0.0.1:9080"
data_dir = "data"
server_secret = "CHANGE_ME_TO_A_LONG_RANDOM_STRING"
rate_limit_per_minute = 30
default_lock_days = 7

# ===================
# TOR
# ===================
[tor]
enabled = true
service_dir = "data/tor"
port = 80
# onion_address = "your-onion-address.onion"  # Uncomment if known

# ===================
# MONERO (XMR)
# ===================
[monero]
wallet_rpc_url = "http://127.0.0.1:18089/json_rpc"
# wallet_rpc_user = "your_username"      # Uncomment and set
# wallet_rpc_password = "your_password"  # Uncomment and set
confirmations_required = 10

# ===================
# BITCOIN (BTC)
# ===================
[bitcoin]
rpc_url = "http://127.0.0.1:8332"
# rpc_user = "your_username"      # Uncomment and set
# rpc_password = "your_password"  # Uncomment and set
confirmations_required = 6
wallet_name = "tor-marketplace"
address_type = "p2sh-segwit"
network = "mainnet"

# ===================
# SECURITY
# ===================
[security]
max_order_value_xmr = 100.0
max_order_value_btc = 1.0
kek_rotation_days = 30
# kek_hex = ""                      # Generated on first start, do not set manually
# kek_version = 1
# last_kek_rotation = 0
# admin_pubkey = ""                 # Hex of admin's ed25519 pubkey for admin routes
btc_min_payment_sats = 546
# master_seed_hex = ""              # Generated on first start, do not set manually

# ===================
# ESCROW
# ===================
[escrow]
fee_percent = 4
# fee_address_btc = "bc1..."       # Uncomment and set for production
# fee_address_xmr = "4..."         # Uncomment and set for production